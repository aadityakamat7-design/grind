{
  "name": "WalletAccount",
  "type": "object",
  "properties": {
    "teen_user_id": {
      "type": "string"
    },
    "balance": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "teen_user_id"
  ],
  "rls": {
    "read": true,
    "write": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}