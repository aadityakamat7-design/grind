      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "earning",
        "save",
        "cashout"
      ]
    },
    "amount": {
      "type": "number"
    },
    "description": {
      "type": "string"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
