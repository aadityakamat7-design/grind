{
  "name": "BuyerProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "full_name": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "zip": {
      "type": "string"
    },
    "id_verification_status": {
      "type": "string",
      "enum": [
        "pending",
        "verified",
        "failed"
      ],
      "default": "pending"
    }
  },
  "required": [
    "user_id"
  ]
}