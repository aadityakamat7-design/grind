{
  "name": "Listing",
  "type": "object",
  "properties": {
    "teen_user_id": {
      "type": "string"
    },
    "teen_profile_id": {
      "type": "string"
    },
    "teen_display_name": {
      "type": "string",
      "maxLength": 50
    },
    "teen_zip": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "tutoring",
        "lawn_care",
        "pet_sitting",
        "tech_help",
        "babysitting",
        "car_washing",
        "odd_jobs"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "price_model": {
      "type": "string",
      "enum": [
        "FIXED",
        "HOURLY"
      ],
      "default": "FIXED"
    },
    "price": {
      "type": "number",
      "minimum": 1,
      "maximum": 500,
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "service_area": {
      "type": "string",
      "description": "ZIP served"
    },
    "is_hazard_flagged": {
      "type": "boolean",
      "default": false,
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "hazard_reason": {
      "type": "string",
      "maxLength": 500,
      "rls": {
        "write": {
          "user_condition": {
            "role": "admin"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "paused"
      ],
      "default": "published"
    }
  },
  "required": [
    "teen_user_id",
    "category",
    "title",
    "price"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": null,
    "update": {
      "$or": [
        {
          "data.teen_user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.teen_user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}